# Zenux engine — optional environment configuration.
# All values below are optional. The scanners and the Claude Code hook
# run fully offline; these only enable remote finding ingestion + telemetry.

# Base URL of a Zenux ingest endpoint (e.g. https://security.example.com).
# Leave unset to run scanners locally and write findings to results/findings.json.
ZENUX_ENDPOINT=

# Bearer token for the Zenux ingest API. Required only if ZENUX_ENDPOINT is set.
INGEST_SECRET=

# Optional: push findings to GitHub Issues instead of / in addition to Zenux.
GITHUB_TOKEN=
GITHUB_REPO=your-org/your-repo

# OpenTelemetry (optional) — emit scan spans to any OTLP collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=zenux
